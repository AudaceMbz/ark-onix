+/*     YouTube Video Feature     */
+.yt-section { padding: 100px var(--gap, 80px); display: flex; flex-direction: column; align-items: center; gap: 32px; }
+.yt-section-label { font-family: var(--font-sans); font-size: 13px; letter-spacing: 0.3em; text-transform: uppercase; color: var(--accent); }
+.yt-section-title { font-family: var(--font-serif); font-size: clamp(2.4rem, 5vw, 4rem); font-weight: 400; color: var(--text); text-align: center; margin: 0; line-height: 1.1; }
+.yt-section-title em { font-style: italic; color: var(--accent); }
+.yt-card-wrapper { position: relative; width: 100%; max-width: 1000px; cursor: pointer; border-radius: 16px; margin-top: 10px; }
+.yt-thumbnail { position: relative; width: 100%; aspect-ratio: 16/9; border-radius: 16px; overflow: hidden; box-shadow: 0 30px 80px rgba(0,0,0,0.5); background: #0a0a0a; transition: transform 0.4s cubic-bezier(.22,.68,0,1.2), box-shadow 0.4s ease; }
+[data-theme='light'] .yt-thumbnail { box-shadow: 0 24px 70px rgba(0,0,0,0.12); }
+.yt-card-wrapper:hover .yt-thumbnail { transform: translateY(-6px) scale(1.02); box-shadow: 0 40px 100px rgba(0,0,0,0.6); }
+[data-theme='light'] .yt-card-wrapper:hover .yt-thumbnail { box-shadow: 0 40px 100px rgba(0,0,0,0.18); }
+.yt-thumbnail img { width: 100%; height: 100%; object-fit: cover; display: block; transition: opacity 0.3s ease; }
+.yt-thumbnail-overlay { position: absolute; inset: 0; background: linear-gradient(to top, rgba(0,0,0,0.65) 0%, transparent 60%); border-radius: 16px; }
+.yt-play-btn { position: absolute; top: 50%; left: 50%; transform: translate(-50%, -50%); width: 84px; height: 58px; background: #FF0000; border-radius: 14px; display: flex; align-items: center; justify-content: center; transition: opacity 0.3s ease, transform 0.3s ease, background 0.2s; pointer-events: none; z-index: 3; box-shadow: 0 8px 30px rgba(255,0,0,0.45); }
+.yt-play-btn svg { width: 26px; height: 26px; fill: #fff; }
+.yt-card-wrapper:hover .yt-play-btn { transform: translate(-50%, -50%) scale(1.1); background: #cc0000; }
+.yt-play-btn.hidden { opacity: 0; transform: translate(-50%, -50%) scale(0.85); }
+.yt-duration { position: absolute; bottom: 16px; right: 20px; background: rgba(0,0,0,0.8); color: #fff; font-family: var(--font-sans); font-size: 14px; font-weight: 600; padding: 4px 10px; border-radius: 6px; letter-spacing: 0.04em; pointer-events: none; z-index: 4; }
+.yt-caption { font-family: var(--font-sans); font-size: 16px; color: var(--text-3); text-align: center; margin-top: 24px; font-weight: 400; letter-spacing: 0.02em; }
+.yt-hover-preview { position: fixed; z-index: 9000; width: 420px; aspect-ratio: 16/9; border-radius: 12px; overflow: hidden; box-shadow: 0 24px 70px rgba(0,0,0,0.7); pointer-events: none; opacity: 0; transform: scale(0.92); transition: opacity 0.3s ease, transform 0.3s cubic-bezier(.22,.68,0,1.2); background: #000; }
+.yt-hover-preview.visible { opacity: 1; transform: scale(1); }
+.yt-hover-preview iframe { width: 100%; height: 100%; border: none; pointer-events: none; }
+.yt-preview-label { position: absolute; bottom: 8px; left: 12px; background: rgba(255,0,0,0.85); color: #fff; font-family: var(--font-sans); font-size: 11px; font-weight: 700; letter-spacing: 0.1em; text-transform: uppercase; padding: 4px 10px; border-radius: 4px; pointer-events: none; }
+.yt-modal-bg { position: fixed; inset: 0; z-index: 9900; background: rgba(0,0,0,0.88); display: flex; align-items: center; justify-content: center; opacity: 0; pointer-events: none; transition: opacity 0.3s ease; backdrop-filter: blur(6px); }
+.yt-modal-bg.open { opacity: 1; pointer-events: all; }
+.yt-modal-inner { position: relative; width: min(90vw, 1100px); aspect-ratio: 16/9; border-radius: 16px; overflow: hidden; box-shadow: 0 40px 100px rgba(0,0,0,0.8); transform: scale(0.92); transition: transform 0.35s cubic-bezier(.22,.68,0,1.2); background: #000; }
+.yt-modal-bg.open .yt-modal-inner { transform: scale(1); }
+.yt-modal-inner iframe { width: 100%; height: 100%; border: none; }
+.yt-modal-close { position: absolute; top: -50px; right: 0; background: rgba(255,255,255,0.1); border: 1px solid rgba(255,255,255,0.2); color: #fff; width: 44px; height: 44px; border-radius: 50%; font-size: 22px; cursor: pointer; display: flex; align-items: center; justify-content: center; transition: background 0.2s; line-height: 1; }
+.yt-modal-close:hover { background: rgba(255,0,0,0.7); }
+@media (max-width: 768px) { .yt-section { padding: 60px 24px; } .yt-hover-preview { display: none !important; } }
 
